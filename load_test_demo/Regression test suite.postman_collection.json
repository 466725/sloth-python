    {
      "name": "Connect-Login",
      "item": [
        {
          "name": "Create session_token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonBody = pm.response.json();",
                  "",
                  "pm.test(\"Status in response is expected\", function(){",
                  "    pm.expect(jsonBody.Result.Status).to.eql(1);",
                  "});",
                  "",
                  "pm.test(\"Result message is successful\", function(){",
                  "    pm.expect(jsonBody.Result.Message[0]).to.eql(\"Successful\");",
                  "});",
                  "",
                  "pm.test(\"Got valid session token\", function(){",
                  "    pm.expect(jsonBody.SessionToken).not.to.be.undefined;",
                  "    pm.expect(jsonBody.SessionToken.length).to.be.above(0);",
                  "    pm.expect(jsonBody.SessionToken).not.to.eql(\"00000000-0000-0000-0000-000000000000\");",
                  "});",
                  "",
                  "console.log(\"Created session_token: \" + jsonBody.SessionToken);",
                  "pm.environment.set(\"session_token\", jsonBody.SessionToken);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n\t\"ApplicationKey\": \"{{application_key}}\"\n}"
            },
            "url": {
              "raw": "{{connect_url}}/ClientServices/CineplexClientServicesWeb/CreateApplicationSession",
              "host": [
                "{{connect_url}}"
              ],
              "path": [
                "ClientServices",
                "CineplexClientServicesWeb",
                "CreateApplicationSession"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login with username and password",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  ""
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonBody = pm.response.json();",
                  "",
                  "console.log(\"Username: \" + pm.variables.get(\"username\"));",
                  "console.log(\"Password: \" + pm.variables.get(\"password\"));",
                  "console.log(\"Session Token: \" + pm.environment.get(\"session_token\"));",
                  "",
                  "pm.test(\"Status in response is expected\", function(){",
                  "    pm.expect(jsonBody.Result.Status).to.eql(1);",
                  "});",
                  "",
                  "pm.test(\"UserProfileGuid generated\", function(){",
                  "    pm.expect(jsonBody.UserProfileGuid).not.to.be.undefined;",
                  "    pm.expect(jsonBody.UserProfileGuid.length).to.be.above(0);",
                  "    pm.expect(jsonBody.UserProfileGuid).not.to.eql(\"00000000-0000-0000-0000-000000000000\");",
                  "});",
                  "",
                  "pm.test(\"UserSessionToken generated\", function(){",
                  "    pm.expect(jsonBody.UserSessionToken).not.to.be.undefined;",
                  "    pm.expect(jsonBody.UserSessionToken.length).to.be.above(0);",
                  "    pm.expect(jsonBody.UserSessionToken).not.to.eql(\"00000000-0000-0000-0000-000000000000\");",
                  "});",
                  "",
                  "pm.environment.set(\"user_profile_guid\", jsonBody.UserProfileGuid);",
                  "pm.environment.set(\"session_token_1\", jsonBody.UserSessionToken);",
                  "",
                  "console.log(\"user_profile_guid: \" + jsonBody.UserProfileGuid);",
                  "console.log(\"session_token_1: \" + jsonBody.UserSessionToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
